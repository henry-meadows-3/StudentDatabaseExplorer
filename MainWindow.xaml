<Window x:Class="StudentWorksheetStarter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentWorksheetStarter"
        mc:Ignorable="d"
        Title="Student Enrollment Viewer"
        Width="800"
        Height="450"
        MinWidth="700"
        MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <!-- ===== Shared Styles ===== -->
    <Window.Resources>

        <!-- Button style (navy, D2L-style) -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#003366"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#004C99"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid column header style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#003366"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <!-- ===== Main Layout ===== -->
    <Grid>

        <!-- Define rows for content and status bar -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <!-- ===== Main Content ===== -->

        <!-- ===== Main Content ===== -->
        <DockPanel Grid.Row="0" LastChildFill="True">

            <!-- Menu Bar -->

            <Menu DockPanel.Dock="Top">
                <MenuItem Header="_File">
                    <MenuItem Header="E_xit"
                  Click="Exit_Click"/>
                </MenuItem>

                <MenuItem Header="_Help">
                    <MenuItem Header="_About"
                  Click="About_Click"/>
                </MenuItem>
            </Menu>


            <!-- Existing content -->
            <StackPanel Margin="20">

                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Source="/Assets/Logo.png"
                   Height="48"
                   Stretch="Uniform"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"/>

                    <!-- (Title text removed as you chose) -->
                </Grid>

                <Separator Margin="0,0,0,15"
                   Background="#003366"
                   Height="2"/>

                <!-- Student name input -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Student Name"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>

                    <TextBox x:Name="StudentNameTextBox"
                     Grid.Column="1"
                     Width="250"
                     HorizontalAlignment="Left"/>
                </Grid>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="AddStudentButton"
                    Content="Add Student"
                    Width="120"
                    Click="AddStudent_Click"/>

                    <Button x:Name="LoadStudentsButton"
                    Content="Load Students"
                    Width="120"
                    Click="LoadStudents_Click"/>

                    <Button x:Name="LoadEnrollmentsButton"
                    Content="Load Enrollments"
                    Width="150"
                    Click="LoadEnrollments_Click"/>
                </StackPanel>

                <!-- Results grid -->
                <DataGrid x:Name="ResultsGrid"
                  AutoGenerateColumns="True"
                  Height="250"
                  ColumnWidth="Auto"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  RowBackground="White"
                  AlternatingRowBackground="#ECEFF1"
                  GridLinesVisibility="Horizontal"/>
            </StackPanel>

        </DockPanel>


        <!-- ===== Status Bar ===== -->
        <StatusBar Grid.Row="1">
            <StatusBarItem>
                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           Foreground="#003366"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
